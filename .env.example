# Live transaction data is fetched from the Zama Dashboard public Supabase instance.
# No API key required — the public anon key is embedded in the app.
# Data source: https://zamadashboard.org/tvs (wrapper_events table)
#
# Optional: reserved for future use or a private Supabase project
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
